# === Core Configuration (Required) ===
DEFAULT_MODEL="deepseek-v4-flash"                # Agent backbone model (DeepSeek)
OPENAI_API_KEY="sk-4c2806c17e5442dc800ecd1648971f67"  # DeepSeek API key (from https://platform.deepseek.com)

# === API Base URLs ===
# NOTE: code reads OPENAI_API_BASE (not OPENAI_BASE_URL)
OPENAI_API_BASE="https://api.deepseek.com"
OPENAI_BASE_URL="https://api.deepseek.com"

# === Search & Crawl Tools (Required only for running Flash-Searcher agents) ===
SERPER_API_KEY="a1f3b309788c177ff5b6b700b6db28160f5ea3a0"       # SerpApi for web search (https://serper.dev/)

# Web crawling - Choose ONE of the following:
# Option 1: JinaAI (requires API key)
JINA_API_KEY="jina_f45cf278b98346cea72bdc0ec1670498vy6qH8drQF2EQTHESLLOSWka-TA1"           # JinaAI for web crawling (https://jina.ai/)
WEB_ACCESS_PROVIDER="jina"                      # Default provider

# Option 2: crawl4ai (free, open-source, no API key needed)
# WEB_ACCESS_PROVIDER="crawl4ai"                # Use crawl4ai instead of Jina

# === Optional: Override specific models ===
 ANALYSIS_MODEL="deepseek-v4-flash"              # Model for trajectory analysis (default: DEFAULT_MODEL)
 GENERATION_MODEL="deepseek-v4-flash"            # Model for system generation (default: DEFAULT_MODEL)
 MSWEA_MODEL_NAME="deepseek-v4-flash"           # Model for auto-fixing (default: DEFAULT_MODEL)